# GOOGLE SHEETS API V4 & OAUTH 2.0 CREDENTIALS CONFIGURATION
# Copy this file to '.env' or '.env.local' and populate with your own keys.
# Vite will automatically load environment variables prefixed with 'VITE_'.

# Spreadsheet ID from the URL of your Google Sheet
VITE_SPREADSHEET_ID=your_google_spreadsheet_id_here

# API Key generated in your Google Cloud Console Credentials
VITE_API_KEY=your_google_api_key_here

# OAuth 2.0 Client ID for Web Applications
VITE_CLIENT_ID=your_oauth_client_id_here
